<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import org.kordamp.ikonli.javafx.*?>

<StackPane fx:id="rootPane" styleClass="popup-background" stylesheets="@../assets/css/project/new-project-form.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.group4.projects_management_fe.features.project.ProjectDetailsFormController">

    <VBox minHeight="550.0" prefWidth="940.0" styleClass="popup-container">

        <HBox>
            <padding>
                <Insets bottom="15.0" left="30.0" right="30.0" top="25.0" />
            </padding>
            <TextField fx:id="projectNameInput" prefHeight="55.0" prefWidth="930.0" promptText="Project name" styleClass="title-input">
            <font>
               <Font size="30.0" />
            </font></TextField>
            <StackPane>
                <Button fx:id="editBtn" minWidth="20.0" mnemonicParsing="false" onAction="#handleEditMode" prefHeight="35.0" prefWidth="10.0" styleClass="btn-edit-circle">
                    <graphic>
                        <FontIcon iconColor="#7D8EA3" iconLiteral="fas-pen" iconSize="20" wrappingWidth="20.0" />
                    </graphic>
                </Button>
                <Button fx:id="deleteBtn" managed="false" minHeight="35.0" minWidth="40.0" mnemonicParsing="false" styleClass="btn-delete" visible="false">
                    <graphic>
                        <FontIcon iconColor="white" iconLiteral="fas-trash" iconSize="20" wrappingWidth="20.0" />
                    </graphic>
                </Button>
            </StackPane>
        </HBox>

        <Separator />

        <HBox VBox.vgrow="ALWAYS">

            <VBox spacing="20.0" styleClass="left-column" HBox.hgrow="ALWAYS">
                <padding>
                    <Insets bottom="30.0" left="30.0" right="20.0" top="25.0" />
                </padding>

                <GridPane hgap="15.0" prefHeight="291.0" prefWidth="541.0" vgap="18.0">
                    <columnConstraints>
                        <ColumnConstraints maxWidth="164.00000762939453" minWidth="140.0" prefWidth="129.2" />
                        <ColumnConstraints hgrow="ALWAYS" maxWidth="425.2" minWidth="385.19999237060546" prefWidth="420.4" />
                    </columnConstraints>

                    <HBox alignment="CENTER_LEFT" spacing="10.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <FontIcon iconLiteral="fas-calendar-alt" styleClass="icon-muted" />
                        <Label styleClass="field-label" text="Start date" />
                    </HBox>
                    <DatePicker fx:id="startDatePicker" promptText="Empty" styleClass="clean-input" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                    <HBox alignment="CENTER_LEFT" spacing="10.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                        <FontIcon iconLiteral="fas-calendar-check" styleClass="icon-muted" />
                        <Label styleClass="field-label" text="End date" />
                    </HBox>
                    <DatePicker fx:id="endDatePicker" promptText="Empty" styleClass="clean-input" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                    <HBox alignment="CENTER_LEFT" spacing="10.0" GridPane.columnIndex="0" GridPane.rowIndex="2">
                        <FontIcon iconLiteral="fas-stream" styleClass="icon-muted" />
                        <Label styleClass="field-label" text="Status" />
                    </HBox>
                    <ComboBox fx:id="statusComboBox" promptText="Empty" styleClass="clean-input" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                    <HBox alignment="CENTER_LEFT" spacing="10.0" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="3">
                        <FontIcon iconLiteral="fas-user-friends" styleClass="icon-muted" />
                        <Label fx:id="memberCountLabel" styleClass="field-label" text="1 member" />
                    </HBox>

                    <HBox alignment="TOP_LEFT" spacing="10.0" GridPane.columnIndex="0" GridPane.rowIndex="4">
                        <FontIcon iconLiteral="fas-align-left" styleClass="icon-muted" />
                        <Label styleClass="field-label" text="Description:" />
                    </HBox>
                    <TextArea fx:id="descriptionInput" prefHeight="70.0" prefRowCount="3" prefWidth="431.0" promptText="Add a description..." styleClass="clean-textarea" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                    <rowConstraints>
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                    </rowConstraints>
                </GridPane>

                <VBox spacing="10.0" VBox.vgrow="SOMETIMES">
                    <Label styleClass="field-label" text="Members" />

                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <Button fx:id="addMemberBtn" onAction="#handleAddMemberClick" styleClass="btn-add-circle" text="+" />
                        <TextField fx:id="memberInput" managed="false" onAction="#handleMemberSubmit" promptText="Enter username" styleClass="clean-input" visible="false" HBox.hgrow="ALWAYS" />
                    </HBox>

                    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" maxHeight="140.0" minHeight="50.0" prefHeight="100.0" styleClass="tags-scroll-pane" vbarPolicy="AS_NEEDED" VBox.vgrow="SOMETIMES">
                        <content>
                            <FlowPane fx:id="memberTagsContainer" hgap="8.0" vgap="8.0" />
                        </content>
                    </ScrollPane>
                </VBox>

            </VBox>

            <Separator orientation="VERTICAL" />

            <VBox minWidth="320.0" prefWidth="320.0" spacing="25.0" styleClass="right-column">
                <padding>
                    <Insets bottom="30.0" left="20.0" right="30.0" top="25.0" />
                </padding>

                <VBox spacing="10.0">
                    <Label styleClass="field-label" text="Created by" />
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <Label fx:id="createdByLabel" styleClass="user-name" text="{Creator}" />
                        <Label fx:id="createdDateLabel" styleClass="date-time" text="{CreateDate}" />
                    </HBox>
                </VBox>

                <VBox spacing="10.0">
                    <Label styleClass="field-label" text="Add Co-Manager" />
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <Button fx:id="addCoManagerBtn" onAction="#handleAddCoManagerClick" styleClass="btn-add-circle" text="+" />
                        <TextField fx:id="coManagerInput" managed="false" onAction="#handleCoManagerSubmit" promptText="Enter username" styleClass="clean-input" visible="false" HBox.hgrow="ALWAYS" />
                    </HBox>
                    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" maxHeight="140.0" minHeight="50.0" prefHeight="100.0" styleClass="tags-scroll-pane" vbarPolicy="AS_NEEDED" VBox.vgrow="SOMETIMES">
                        <content>
                            <FlowPane fx:id="coManagerTagsContainer" hgap="8.0" vgap="8.0" />
                        </content>
                    </ScrollPane>
                </VBox>

                <HBox alignment="CENTER" minHeight="120.0" prefHeight="130.0" prefWidth="270.0">
                    <VBox prefHeight="130.0" prefWidth="135.0">
                        <VBox alignment="CENTER_LEFT" prefHeight="65.0" prefWidth="135.0">
                            <Label styleClass="user-name" text="Total" />
                            <Label fx:id="totalTasks" styleClass="user-name" text="{Creator}" textAlignment="CENTER">
                        <VBox.margin>
                           <Insets left="30.0" />
                        </VBox.margin></Label>
                        </VBox>
                        <VBox alignment="CENTER_LEFT" prefHeight="65.0" prefWidth="135.0">
                            <Label styleClass="user-name" text="Progress" />
                            <Label fx:id="percentage" styleClass="user-name" text="{CreateDate}" textAlignment="CENTER">
                        <VBox.margin>
                           <Insets left="30.0" />
                        </VBox.margin></Label>
                        </VBox>
                    </VBox>
                    <VBox prefHeight="130.0" prefWidth="135.0">
                        <VBox alignment="CENTER_LEFT" prefHeight="65.0" prefWidth="135.0">
                            <Label styleClass="user-name" text="On going" />
                            <Label fx:id="inProgress" styleClass="user-name" text="{Creator}" textAlignment="CENTER">
                        <VBox.margin>
                           <Insets left="30.0" />
                        </VBox.margin></Label>
                        </VBox>
                        <VBox alignment="CENTER_LEFT" prefHeight="65.0" prefWidth="135.0">
                            <Label styleClass="user-name" text="Completed" />
                            <Label fx:id="completed" styleClass="user-name" text="{CreateDate}" textAlignment="CENTER">
                        <VBox.margin>
                           <Insets left="30.0" />
                        </VBox.margin></Label>
                        </VBox>
                    </VBox>
                </HBox>

                <VBox prefWidth="270.0" spacing="10.0">
                    <Label styleClass="field-label" text="Last updated at" />
                    <HBox alignment="CENTER_LEFT">
                        <Label fx:id="lastUpdatedDateLabel" styleClass="date-time" text="{UpdateDate}" />
                    </HBox>
                </VBox>

                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <Button fx:id="leaveBtn" managed="false" minHeight="35.0" minWidth="80.0" mnemonicParsing="false" onAction="#handleLeaveProject" styleClass="btn-leave" text="Leave" textFill="#d32f2f" visible="false" />

                    <Region HBox.hgrow="ALWAYS" />

                    <Button fx:id="cancelBtn" cancelButton="true" minHeight="35.0" minWidth="80.0" mnemonicParsing="false" onAction="#handleCancel" styleClass="btn-cancel" text="Cancel" />
                    <Button fx:id="saveBtn" defaultButton="true" managed="false" minHeight="35.0" minWidth="80.0" mnemonicParsing="false" onAction="#handleSave" styleClass="btn-create" text="Save" visible="false" />
                </HBox>
            </VBox>

        </HBox>
    </VBox>
</StackPane>
