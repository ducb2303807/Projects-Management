<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.group4.projects_management_fe.features.auth.MainLayoutController">

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="70" spacing="40" styleClass="top-bar">
            <StackPane fx:id="logoContainer">
                <ImageView fx:id="logoImage" fitHeight="70.0" fitWidth="140.0" preserveRatio="true">
                    <image>
                        <Image url="@../assets/image/logo_v5.png"/>
                    </image>
                </ImageView>
            </StackPane>

            <HBox alignment="CENTER_LEFT" spacing="30">
                <Button fx:id="dashboardBtn" minWidth="80.0" onAction="#showDashboard" styleClass="nav-btn" text="Dashboard"/>
                <Button fx:id="projectsBtn" minWidth="80.0" onAction="#showProjects" styleClass="nav-btn" text="Projects"/>
                <Button fx:id="tasksBtn" minWidth="80.0" onAction="#showTasks" styleClass="nav-btn" text="Tasks"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <StackPane>
                <Button fx:id="notifBtn" styleClass="notif-btn">
                    <graphic>
                        <FontIcon iconLiteral="fas-bell" styleClass="notif-icon"/>
                    </graphic>
                </Button>
            </StackPane>

            <HBox alignment="CENTER" spacing="10" styleClass="user-box" fx:id="userBox">
                <StackPane styleClass="avatar">
                    <ImageView fx:id="avatarImage"
                               fitHeight="40"
                               fitWidth="40"
                               preserveRatio="false"
                               styleClass="avt">
                        <image>
                            <Image url="@../assets/image/background.jpg"/>
                        </image>
                    </ImageView>
                </StackPane>

                <VBox spacing="2">
                    <Label text="User"/>
                    <Label styleClass="role-text" text="Project Manager"/>
                </VBox>
            </HBox>

            <padding>
                <Insets bottom="0" left="40" right="40" top="0"/>
            </padding>
        </HBox>
    </top>

    <!-- CENTER -->
    <center>
        <StackPane>

            <StackPane fx:id="contentPane" style="-fx-padding:40;"/>

            <StackPane fx:id="profileOverlay"
                       visible="false"
                       managed="false"
                       styleClass="overlay">

                <StackPane fx:id="overlayBackground"
                           styleClass="overlay-bg"/>

                <VBox fx:id="profilePanel"
                      prefWidth="480"
                      prefHeight="380"
                      maxWidth="480"
                      maxHeight="380"
                      styleClass="profile-panel"
                      spacing="15">

                    <HBox spacing="40" alignment="CENTER_LEFT" styleClass="profile-header">
                        <Label text="Profile" styleClass="tab-active"/>
                        <Label text="Password" styleClass="tab"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Log out" styleClass="logout-btn" onAction="#handleLogout"/>
                    </HBox>

                    <VBox spacing="5">
                        <Label text="Username" styleClass="field-label"/>
                        <TextField text="Invincible" styleClass="profile-field"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Fullname" styleClass="field-label"/>
                        <TextField text="Nam" styleClass="profile-field"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Email" styleClass="field-label"/>
                        <TextField text="hanb2303809@student.ctu.edu.vn" styleClass="profile-field"/>
                    </VBox>

                    <Region VBox.vgrow="ALWAYS"/>

                    <HBox spacing="20" alignment="CENTER_RIGHT">
                        <Button text="Cancel" onAction="#hideProfile"/>
                        <Button text="Save" styleClass="save-btn"/>
                    </HBox>

                </VBox>
            </StackPane>

        </StackPane>
    </center>

    <!-- FOOTER -->
    <bottom>
        <HBox alignment="CENTER"
              prefHeight="60"
              styleClass="footer-bar"
              spacing="10">

            <StackPane fx:id="logoFooter">
                <ImageView fx:id="logoImageFooter"
                           fitHeight="70.0"
                           fitWidth="90.0"
                           preserveRatio="true">
                    <image>
                        <Image url="@../assets/image/logo_footer.png"/>
                    </image>
                </ImageView>
            </StackPane>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="© 2026 Nexus Team. All Rights Reserved"
                   styleClass="footer-text"/>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox alignment="CENTER" spacing="40">
                <Label text="D3n"/>
                <Label text="enda"/>
                <Label text="hunny"/>
                <Label text="He11Cat"/>
                <Label text="NamIvbs02"/>
            </HBox>

        </HBox>
    </bottom>

</BorderPane>