<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.group4.projects_management_fe.features.mainlayout.MainLayoutController">

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="70" spacing="40" styleClass="top-bar">
            <StackPane fx:id="logoContainer">
                <ImageView fx:id="logoImage" fitHeight="70.0" fitWidth="140.0" preserveRatio="true">
                    <image>
                        <Image url="@../assets/image/logo_v5.png" />
                    </image>
                </ImageView>
            </StackPane>

            <HBox alignment="CENTER_LEFT" spacing="30">
                <Button fx:id="dashboardBtn" minWidth="80.0" onAction="#showDashboard" styleClass="nav-btn" text="Dashboard" />
                <Button fx:id="projectsBtn" minWidth="80.0" onAction="#showProjects" styleClass="nav-btn" text="Projects" />
                <Button fx:id="tasksBtn" minWidth="80.0" onAction="#showTasks" styleClass="nav-btn" text="Tasks" />
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <StackPane>
                <Button fx:id="notifBtn" styleClass="notif-btn">
                    <graphic>
                        <FontIcon iconLiteral="fas-bell" styleClass="notif-icon" />
                    </graphic>
                </Button>
            </StackPane>

            <HBox fx:id="userBox" alignment="CENTER" spacing="10" styleClass="user-box">
                <StackPane styleClass="avatar">
                    <ImageView fx:id="avatarImage" fitHeight="40" fitWidth="40" preserveRatio="false" styleClass="avt">
                        <image>
                            <Image url="@../assets/image/background.jpg" />
                        </image>
                    </ImageView>
                </StackPane>

                <VBox spacing="2">
                    <Label text="User" />
                    <Label styleClass="role-text" text="Project Manager" />
                </VBox>
            </HBox>

            <padding>
                <Insets bottom="0" left="40" right="40" top="0" />
            </padding>
        </HBox>
    </top>

    <!-- CENTER -->
    <center>
        <StackPane>

            <StackPane fx:id="contentPane" style="-fx-padding:40;" />

            <StackPane fx:id="profileOverlay" managed="false" styleClass="overlay" visible="false">

                <StackPane fx:id="overlayBackground" styleClass="overlay-bg" />

                <VBox fx:id="profilePanel" maxHeight="380" maxWidth="480" prefHeight="380" prefWidth="480" spacing="15" styleClass="profile-panel">

                    <HBox alignment="CENTER_LEFT" spacing="40" styleClass="profile-header">
                        <Label styleClass="tab-active" text="Profile" />
                        <Label styleClass="tab" text="Password" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#handleLogout" styleClass="logout-btn" text="Log out" />
                    </HBox>

                    <VBox spacing="5">
                        <Label styleClass="field-label" text="Username" />
                        <TextField styleClass="profile-field" text="Invincible" />
                    </VBox>

                    <VBox spacing="5">
                        <Label styleClass="field-label" text="Fullname" />
                        <TextField styleClass="profile-field" text="Nam" />
                    </VBox>

                    <VBox spacing="5">
                        <Label styleClass="field-label" text="Email" />
                        <TextField styleClass="profile-field" text="hanb2303809@student.ctu.edu.vn" />
                    </VBox>

                    <Region VBox.vgrow="ALWAYS" />

                    <HBox alignment="CENTER_RIGHT" spacing="20">
                        <Button onAction="#hideProfile" text="Cancel" />
                        <Button styleClass="save-btn" text="Save" />
                    </HBox>

                </VBox>
            </StackPane>

        </StackPane>
    </center>

    <!-- FOOTER -->
    <bottom>
        <HBox alignment="CENTER" prefHeight="60" spacing="10" styleClass="footer-bar">

            <StackPane fx:id="logoFooter" />
             <ImageView fx:id="logoImageFooter" fitHeight="50.0" fitWidth="60.0" preserveRatio="true">
                 <image>
                     <Image url="@../assets/image/logo_footer_v2.png" />
                 </image>
            <HBox.margin>
               <Insets left="20.0" />
            </HBox.margin>
             </ImageView>

            <Region HBox.hgrow="ALWAYS" />

            <Label styleClass="footer-text" text="© 2026 Nexus Team. All Rights Reserved" />

            <Region HBox.hgrow="ALWAYS" />

            <HBox alignment="CENTER" spacing="40">
                <Label text="D3n" />
                <Label text="enda" />
                <Label text="hunny" />
                <Label text="He11Cat" />
                <Label text="NamIvbs02" />
            <padding>
               <Insets right="20.0" />
            </padding>
            </HBox>

        </HBox>
    </bottom>

</BorderPane>
