<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<BorderPane style="-fx-background-color: #F8F9FA;" styleClass="main-layout-container" stylesheets="@../assets/css/auth.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.group4.projects_management_fe.features.mainlayout.MainLayoutController">

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" maxHeight="-Infinity" prefHeight="80.0" spacing="40" style="-fx-view-order: -1;" styleClass="top-bar">
            <StackPane fx:id="logoContainer">
                <ImageView fx:id="logoImage" fitHeight="80.0" fitWidth="160.0" preserveRatio="true">
                    <image>
                        <Image url="@../assets/image/logo_v5.png" />
                    </image>
                </ImageView>
            </StackPane>
            <Region prefHeight="80.0" prefWidth="220.0" />

            <HBox alignment="CENTER" spacing="30">
                <Button fx:id="dashboardBtn" maxHeight="-Infinity" minWidth="80.0" onAction="#showDashboard" prefHeight="80.0" styleClass="nav-btn" text="Dashboard" />
                <Button fx:id="projectsBtn" maxHeight="-Infinity" minWidth="80.0" onAction="#showProjects" prefHeight="80.0" styleClass="nav-btn" text="Projects" />
                <Button fx:id="tasksBtn" maxHeight="-Infinity" minWidth="80.0" onAction="#showTasks" prefHeight="80.0" styleClass="nav-btn" text="Tasks" />
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <StackPane>
                <Button fx:id="notifBtn" styleClass="notif-btn">
                    <graphic>
                        <FontIcon iconLiteral="fas-bell" styleClass="notif-icon" />
                    </graphic>
                </Button>

                <Label fx:id="notifBadge" alignment="CENTER" managed="false" styleClass="notif-badge" text="0" visible="false" StackPane.alignment="TOP_RIGHT">
                    <StackPane.margin>
                        <Insets right="5.0" top="5.0" />
                    </StackPane.margin>
                </Label>
            </StackPane>

            <HBox fx:id="userBox" alignment="CENTER_LEFT" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="50.0" prefWidth="180.0" spacing="10" styleClass="user-box">
                <StackPane maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="40.0" prefWidth="40.0" styleClass="avatar">
                    <ImageView fx:id="avatarImage" fitHeight="30.0" fitWidth="30.0" preserveRatio="false" styleClass="avatar">

                    </ImageView>
                </StackPane>

                <VBox alignment="CENTER_LEFT" maxHeight="-Infinity" prefHeight="40.0" spacing="2">
                    <Label fx:id="usernameLabel" text="User" />
                    <Label fx:id="roleLabel" styleClass="role-text" text="Project Manager" />
                </VBox>
            </HBox>

            <padding>
                <Insets bottom="0" left="40" right="40" top="0" />
            </padding>
            <BorderPane.margin>
                <Insets />
            </BorderPane.margin>
        </HBox>
    </top>

    <!-- CENTER -->
    <center>
        <StackPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" BorderPane.alignment="TOP_CENTER">

            <StackPane fx:id="contentPane" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="0.0" prefWidth="1070.0" />

            <StackPane fx:id="profileOverlay" managed="false" maxHeight="Infinity" maxWidth="Infinity" prefHeight="Infinity" prefWidth="Infinity" styleClass="overlay" visible="false" StackPane.alignment="CENTER">

                <StackPane fx:id="overlayBackground" styleClass="overlay-bg" />

                <VBox fx:id="profilePanel" maxHeight="380" maxWidth="480" prefHeight="380" prefWidth="480" spacing="15" styleClass="profile-panel">

                    <!-- HEADER -->
                    <HBox alignment="CENTER_LEFT" spacing="40" styleClass="profile-header">
                        <Label fx:id="profileTab" onMouseClicked="#showProfileTab" styleClass="tab-active" text="Profile" />

                        <Label fx:id="passwordTab" onMouseClicked="#showPasswordTab" styleClass="tab" text="Password" />

                        <Region HBox.hgrow="ALWAYS" />

                        <Button onAction="#handleLogout" styleClass="logout-btn" text="Log out" />
                    </HBox>

                    <!-- CONTENT SWITCH -->
                    <StackPane fx:id="tabContent">

                        <VBox fx:id="profileContent" spacing="15">

                            <VBox spacing="5">
                                <Label styleClass="field-label" text="Username" />
                                <TextField fx:id="usernameField" editable="false" styleClass="profile-field" />
                            </VBox>

                            <VBox spacing="5">
                                <Label styleClass="field-label" text="Fullname" />
                                <TextField fx:id="fullnameField" editable="true" styleClass="profile-field" />
                            </VBox>

                            <VBox spacing="5">
                                <Label styleClass="field-label" text="Email" />
                                <TextField fx:id="emailField" editable="true" styleClass="profile-field" />
                            </VBox>

                            <Region VBox.vgrow="ALWAYS" />

                            <HBox alignment="CENTER_RIGHT" spacing="20">
                                <Button onAction="#hideProfile" styleClass="cancel-btn" text="Cancel" />
                                <Button onAction="#handleSaveProfile" styleClass="save-btn" text="Save" />
                            </HBox>

                        </VBox>

                        <!-- ================= PASSWORD ================= -->
                        <VBox fx:id="passwordContent" managed="false" spacing="15" visible="false">

                            <VBox spacing="5">
                                <Label styleClass="field-label" text="Current Password" />
                                <PasswordField fx:id="currentPasswordField" styleClass="profile-field" />
                            </VBox>

                            <VBox spacing="5">
                                <Label styleClass="field-label" text="New Password" />
                                <PasswordField fx:id="newPasswordField" styleClass="profile-field" />
                            </VBox>

                            <VBox spacing="5">
                                <Label styleClass="field-label" text="Confirm Password" />
                                <PasswordField fx:id="confirmPasswordField" styleClass="profile-field" />
                            </VBox>

                            <Region VBox.vgrow="ALWAYS" />

                            <HBox alignment="CENTER_RIGHT" spacing="20">
                                <Button onAction="#hideProfile" styleClass="cancel-btn" text="Cancel" />
                                <Button onAction="#handleChangePassword" styleClass="save-btn" text="Save" />
                            </HBox>

                        </VBox>

                    </StackPane>

                </VBox>
            </StackPane>

        </StackPane>
    </center>

    <!-- FOOTER -->
    <bottom>
        <HBox alignment="CENTER" prefHeight="40.0" prefWidth="898.0" spacing="10" styleClass="footer-bar">

            <StackPane fx:id="logoFooter" />
            <ImageView fx:id="logoImageFooter" fitHeight="50.0" fitWidth="60.0" preserveRatio="true">
                <image>
                    <Image url="@../assets/image/logo_footer_v2.png" />
                </image>
                <HBox.margin>
                    <Insets left="20.0" />
                </HBox.margin>
            </ImageView>

            <Region HBox.hgrow="ALWAYS" />

            <Label styleClass="footer-text" text="© 2026 Nexus Team. All Rights Reserved" />

            <Region HBox.hgrow="ALWAYS" />

            <HBox alignment="CENTER" spacing="40">
                <Label text="D3n" />
                <Label text="enda" />
                <Label text="hunny" />
                <Label text="He11Cat" />
                <Label text="NamIvbs02" />
                <padding>
                    <Insets right="20.0" />
                </padding>
            </HBox>

        </HBox>
    </bottom>

</BorderPane>
