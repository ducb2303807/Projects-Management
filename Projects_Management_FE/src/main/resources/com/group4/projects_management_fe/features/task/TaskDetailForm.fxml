<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<StackPane fx:id="rootPane" stylesheets="@../assets/css/tasks/new-task-form.css"
           xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.group4.projects_management_fe.features.task.TaskDetailFormController">
    <Pane styleClass="popup-background"/>

    <VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="500.0" prefHeight="550.0" prefWidth="780.0"
          styleClass="popup-container">

        <!-- Header: Task name -->
        <VBox>
            <padding>
                <Insets bottom="10.0" left="30.0" right="30.0" top="10.0"/>
            </padding>
            <GridPane>
                <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" maxWidth="650.0" minWidth="10.0" prefWidth="650.0"/>
                    <ColumnConstraints halignment="CENTER" hgrow="SOMETIMES" minWidth="10.0"/>
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints minHeight="10.0" vgrow="SOMETIMES"/>
                </rowConstraints>
                <children>
                    <TextField fx:id="taskNameInput" promptText="Task name" styleClass="title-input"/>
                    <StackPane fx:id="deleteTaskBtn" onMouseClicked="#handleDeleteTask" maxHeight="-Infinity"
                               maxWidth="-Infinity" prefHeight="35.0" prefWidth="35.0" styleClass="trash-btn-container"
                               GridPane.columnIndex="1">
                        <FontIcon iconLiteral="fas-trash" styleClass="trash-btn"/>
                    </StackPane>
                </children>
            </GridPane>
        </VBox>

        <Separator/>

        <HBox VBox.vgrow="ALWAYS">

            <!-- Cột trái: metadata (giống NewProjectForm.fxml) -->
            <VBox prefHeight="446.0" prefWidth="425.0" spacing="5.0" styleClass="left-column" HBox.hgrow="ALWAYS">
                <padding>
                    <Insets bottom="30.0" left="30.0" right="20.0" top="25.0"/>
                </padding>

                <GridPane hgap="15.0" vgap="10.0">
                    <columnConstraints>
                        <ColumnConstraints maxWidth="122.00000762939453" minWidth="100.0"
                                           prefWidth="122.00000762939453"/>
                        <ColumnConstraints hgrow="ALWAYS" maxWidth="240.0" minWidth="222.99999237060547"
                                           prefWidth="222.99999237060547"/>
                    </columnConstraints>

                    <!-- Due date -->
                    <HBox alignment="CENTER_LEFT" spacing="10.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <FontIcon iconLiteral="fas-calendar-alt" styleClass="icon-muted"/>
                        <Label styleClass="field-label" text="Due date"/>
                    </HBox>
                    <DatePicker fx:id="dueDatePicker" promptText="Empty" styleClass="clean-input-date"
                                GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                    <!-- Status -->
                    <HBox alignment="CENTER_LEFT" spacing="10.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                        <FontIcon iconLiteral="fas-stream" styleClass="icon-muted"/>
                        <Label styleClass="field-label" text="Status"/>
                    </HBox>
                    <ComboBox fx:id="statusComboBox" promptText="Empty" styleClass="clean-input"
                              GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <!-- Priority -->
                    <HBox alignment="CENTER_LEFT" spacing="10.0" GridPane.columnIndex="0" GridPane.rowIndex="2">
                        <FontIcon iconLiteral="fas-exclamation-triangle" styleClass="icon-muted"/>
                        <Label styleClass="field-label" text="Priority"/>
                    </HBox>
                    <ComboBox fx:id="priorityComboBox" promptText="Empty" styleClass="clean-input"
                              GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                    <!-- Assignee -->
                    <HBox alignment="CENTER_LEFT" spacing="10.0" GridPane.columnIndex="0" GridPane.rowIndex="3">
                        <FontIcon iconLiteral="fas-user-friends" styleClass="icon-muted"/>
                        <Label styleClass="field-label" text="Assignee"/>
                    </HBox>

                    <VBox alignment="CENTER_LEFT" spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="3">
                        <FlowPane fx:id="assigneeChipsPane" hgap="6" maxWidth="1.7976931348623157E308" vgap="6"/>
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Button fx:id="addAssigneeBtn" managed="false" onAction="#handleAddAssigneeClick"
                                    styleClass="btn-add-circle" text="+" visible="false"/>
                            <TextField fx:id="assigneeInput" managed="false" onAction="#handleAssigneeSubmit"
                                       promptText="Enter username" styleClass="clean-input" visible="false"
                                       HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>

                    <!-- Description -->
                    <HBox alignment="CENTER_LEFT" spacing="10.0" GridPane.columnIndex="0" GridPane.rowIndex="4">
                        <FontIcon iconLiteral="fas-align-left" styleClass="icon-muted"/>
                        <Label prefHeight="26.0" prefWidth="98.0" styleClass="field-label" text="Description:"/>
                    </HBox>
                    <rowConstraints>
                        <RowConstraints/>
                        <RowConstraints/>
                        <RowConstraints/>
                        <RowConstraints/>
                        <RowConstraints/>
                    </rowConstraints>
                </GridPane>
                <TextArea fx:id="descriptionInput" prefHeight="145.0" prefRowCount="4" prefWidth="360.0"
                          promptText="Add a description..." styleClass="clean-textarea" wrapText="true"/>
            </VBox>

            <Separator orientation="VERTICAL"/>

            <!-- Cột phải: Last edited + Comments (đúng giao diện ảnh) -->
            <VBox minWidth="320.0" prefHeight="446.0" prefWidth="380.0" spacing="25.0" styleClass="right-column">
                <padding>
                    <Insets bottom="30.0" left="20.0" right="30.0" top="25.0"/>
                </padding>
                <GridPane vgap="15.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0"/>
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" vgrow="SOMETIMES"/>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                    </rowConstraints>
                    <children>
                        <GridPane>
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="151.40001220703124" minWidth="10.0"
                                                   prefWidth="140.2"/>
                                <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" maxWidth="199.39996337890625"
                                                   minWidth="10.0" prefWidth="173.0"/>
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="10.0" vgrow="SOMETIMES"/>
                            </rowConstraints>
                            <children>
                                <Label styleClass="field-label" text="Last edited by"/>
                                <Button fx:id="showDetails" onAction="#handleOpenHistoryDetails" mnemonicParsing="false" prefHeight="26.0" prefWidth="100.0"
                                        styleClass="show-detail" text="Show details" GridPane.columnIndex="1"/>
                            </children>
                        </GridPane>
                        <HBox alignment="CENTER_LEFT" spacing="10.0" GridPane.rowIndex="1">
                            <Label fx:id="lastEditedAvatarLabel" styleClass="avatar"/>
                            <Label fx:id="usernameLabel" styleClass="user-name"/>
                            <Label fx:id="editedAtLabel" styleClass="date-time"/>
                        </HBox>
                    </children>
                </GridPane>

                <!-- Comments -->
                <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                    <Label styleClass="field-label" text="Comments"/>

                    <!-- Danh sách comments (dynamic) -->
                    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" maxHeight="220.0" minHeight="80.0"
                                prefHeight="180.0" styleClass="tags-scroll-pane" vbarPolicy="AS_NEEDED"
                                VBox.vgrow="SOMETIMES">
                        <content>
                            <VBox fx:id="commentsContainer" spacing="12.0"/>
                        </content>
                    </ScrollPane>

                    <!-- Add comment -->
                    <HBox alignment="CENTER_LEFT" spacing="8.0">
                        <Label fx:id="myAvatarLabel" styleClass="avatar"/>
                        <TextField fx:id="commentField" onAction="#handleCommentSubmit" promptText="Add a comment..."
                                   style="-fx-background-color: #F5F5F5; -fx-background-radius: 20; -fx-padding: 6 14; -fx-border-color: transparent;"
                                   HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <!-- Buttons -->
                <HBox alignment="BOTTOM_RIGHT" spacing="15.0">
                    <Button cancelButton="true" minHeight="35.0" minWidth="80.0" mnemonicParsing="false"
                            onAction="#handleCancel" styleClass="btn-cancel" text="Cancel"/>
                    <Button fx:id="saveBtn" defaultButton="true" minHeight="35.0" minWidth="90.0"
                            mnemonicParsing="false" onAction="#handleSave" styleClass="btn-create" text="Save"/>
                </HBox>
            </VBox>

        </HBox>
    </VBox>
</StackPane>
