<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox fx:id="taskItemRoot" alignment="CENTER_LEFT" spacing="12" styleClass="task-item-row"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.group4.projects_management_fe.features.task.TaskItemController">

    <!-- LEFT: Checkbox + Task name + Comment count -->
    <HBox alignment="CENTER_LEFT" spacing="8">
        <CheckBox fx:id="taskCheckBox" mnemonicParsing="false"/>
        <Label fx:id="taskNameLabel" styleClass="task-name" text="Task name"/>
    </HBox>

    <Region HBox.hgrow="ALWAYS"/>

    <!-- RIGHT: Due date | Assignee | Priority | More -->
    <HBox alignment="CENTER_LEFT" spacing="24">
        <Label fx:id="dueDateLabel" styleClass="due-date" text="Mar 31, 2026"/>

        <!-- Assignee -->
        <HBox fx:id="assigneeBox" spacing="4" alignment="CENTER_LEFT">
            <Label fx:id="assigneeAvatar" styleClass="avatar-circle" text="H"/>
            <Label fx:id="assigneeOverflow" styleClass="assignee-overflow" text="+2" visible="false"/>
        </HBox>

        <!-- Priority badge -->
        <Label fx:id="priorityLabel" styleClass="priority-badge" text="High"/>

        <!-- More button -->
        <Button fx:id="moreButton" text="⋯" styleClass="more-button" onAction="#onMoreOptionsClicked"/>
    </HBox>
</HBox>