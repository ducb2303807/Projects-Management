<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<StackPane styleClass="popup-background" stylesheets="@../assets/css/new-project-form.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.group4.projects_management_fe.features.project.NewProjectFormController">

    <VBox prefWidth="750.0" minHeight="500.0" styleClass="popup-container">

        <VBox>
            <padding>
                <Insets top="25.0" right="30.0" bottom="15.0" left="30.0"/>
            </padding>
            <TextField fx:id="projectNameInput" promptText="Project name" styleClass="title-input" />
        </VBox>

        <Separator />

        <HBox VBox.vgrow="ALWAYS">

            <VBox HBox.hgrow="ALWAYS" spacing="20.0" styleClass="left-column">
                <padding>
                    <Insets top="25.0" right="20.0" bottom="30.0" left="30.0"/>
                </padding>

                <GridPane vgap="18.0" hgap="15.0">
                    <columnConstraints>
                        <ColumnConstraints minWidth="100.0" prefWidth="120.0" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>

                    <HBox alignment="CENTER_LEFT" spacing="10.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <FontIcon iconLiteral="fas-calendar-alt" styleClass="icon-muted"/>
                        <Label text="Start date" styleClass="field-label"/>
                    </HBox>
                    <DatePicker fx:id="startDatePicker" promptText="Empty" styleClass="clean-input" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                    <HBox alignment="CENTER_LEFT" spacing="10.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                        <FontIcon iconLiteral="fas-calendar-check" styleClass="icon-muted"/>
                        <Label text="End date" styleClass="field-label"/>
                    </HBox>
                    <DatePicker fx:id="endDatePicker" promptText="Empty" styleClass="clean-input" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                    <HBox alignment="CENTER_LEFT" spacing="10.0" GridPane.columnIndex="0" GridPane.rowIndex="2">
                        <FontIcon iconLiteral="fas-stream" styleClass="icon-muted"/>
                        <Label text="Status" styleClass="field-label"/>
                    </HBox>
                    <ComboBox fx:id="statusComboBox" promptText="Empty" styleClass="clean-input" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                    <HBox alignment="CENTER_LEFT" spacing="10.0" GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.columnSpan="2">
                        <FontIcon iconLiteral="fas-user-friends" styleClass="icon-muted"/>
                        <Label fx:id="memberCountLabel" text="1 member" styleClass="field-label"/>
                    </HBox>

                    <HBox alignment="TOP_LEFT" spacing="10.0" GridPane.columnIndex="0" GridPane.rowIndex="4">
                        <FontIcon iconLiteral="fas-align-left" styleClass="icon-muted"/>
                        <Label text="Description:" styleClass="field-label"/>
                    </HBox>
                    <TextArea fx:id="descriptionInput" promptText="Add a description..." wrapText="true" prefRowCount="3" styleClass="clean-textarea" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                </GridPane>
            </VBox>

            <Separator orientation="VERTICAL" />

            <VBox minWidth="320.0" prefWidth="320.0" spacing="25.0" styleClass="right-column">
                <padding>
                    <Insets top="25.0" right="30.0" bottom="30.0" left="20.0"/>
                </padding>

                <VBox spacing="10.0">
                    <Label text="Created by" styleClass="field-label"/>
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <Label text="Hunny" styleClass="user-name"/>
                        <Label text="Feb 14, 2026, 11:32 PM" styleClass="date-time"/>
                    </HBox>
                </VBox>

                <VBox spacing="10.0">
                    <Label text="Add Co-Manager" styleClass="field-label"/>
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <Button fx:id="addCoManagerBtn" text="+" onAction="#handleAddCoManagerClick" styleClass="btn-add-circle"/>
                        <TextField fx:id="coManagerInput" promptText="Enter username..." onAction="#handleCoManagerSubmit" styleClass="clean-input" visible="false" managed="false" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <FlowPane fx:id="coManagerTagsContainer" hgap="8.0" vgap="8.0" />
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <VBox spacing="10.0">
                    <Label text="Last updated by" styleClass="field-label"/>
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <Label text="Hunny" styleClass="user-name"/>
                        <Label text="Feb 14, 2026, 11:32 PM" styleClass="date-time"/>
                    </HBox>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <HBox alignment="BOTTOM_RIGHT" spacing="15.0">
                    <Button cancelButton="true" mnemonicParsing="false" onAction="#handleCancel" styleClass="btn-cancel" text="Cancel" minWidth="80.0" minHeight="35.0"/>
                    <Button defaultButton="true" mnemonicParsing="false" onAction="#handleCreate" styleClass="btn-create" text="Create" minWidth="90.0" minHeight="35.0"/>
                </HBox>
            </VBox>

        </HBox>
    </VBox>
</StackPane>