<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="710.0" prefWidth="1100.0" styleClass="root" stylesheets="@../assets/css/project/projecttasks.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">

    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="30.0" />
    </padding>

    <children>
        <HBox alignment="CENTER_LEFT">
            <children>
                <Label fx:id="projectNameLabel" prefHeight="30.0" prefWidth="550.0" styleClass="section-title" text="Project name" />

                <Region prefHeight="38.0" prefWidth="30.0" HBox.hgrow="ALWAYS" />

                <HBox alignment="CENTER" spacing="15.0">
                    <children>
                        <TextField fx:id="searchInput" managed="true" prefWidth="200.0" promptText="Search task" styleClass="search-input" visible="true" />
                        <Button fx:id="searchTaskBtn" mnemonicParsing="false" styleClass="icon-btn" text="🔍" />
                        <ComboBox fx:id="sortTaskComboBox" managed="false" prefWidth="120.0" promptText="Sort by" styleClass="clean-input" visible="false" />
                        <Button fx:id="sortTaskBtn" mnemonicParsing="false" styleClass="icon-btn" text="⇅" />
                        <Button fx:id="newTaskBtn" mnemonicParsing="false" styleClass="btn-new" text="+ New" />
                    </children>
                </HBox>
            </children>
         <padding>
            <Insets left="10.0" right="10.0" />
         </padding>
        </HBox>

        <Pane prefHeight="600.0" prefWidth="1058.0" VBox.vgrow="ALWAYS">
            <VBox fx:id="taskGroupsContainer" layoutY="-2.0" prefHeight="565.0" prefWidth="1058.0" spacing="20.0">
                <children>
                    <fx:include source="/com/group4/projects_management_fe/features/task/TaskListInProject.fxml" />
                </children>
            </VBox>
            <VBox.margin>
                <Insets bottom="15" left="10.0" right="10.0" top="15.0" />
            </VBox.margin>
        </Pane>
        <HBox alignment="BOTTOM_RIGHT" prefWidth="1081.0" spacing="15.0">
            <Button cancelButton="true" minHeight="35.0" minWidth="80.0" mnemonicParsing="false" styleClass="btn-cancel" text="Cancel" textAlignment="CENTER" />
         <VBox.margin>
            <Insets top="15.0" />
         </VBox.margin>
        </HBox>
    </children>
</VBox>
