<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="710.0" prefWidth="1100.0" styleClass="root" stylesheets="@../assets/css/project/projecttasks.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.group4.projects_management_fe.features.project.ProjectTasksController">

    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="30.0" />
    </padding>

    <children>
        <HBox alignment="CENTER_LEFT">
            <children>
                <Label fx:id="projectNameLabel" prefHeight="30.0" prefWidth="550.0" styleClass="section-title" text="Project name" />

                <Region prefHeight="38.0" prefWidth="30.0" HBox.hgrow="ALWAYS" />

                <HBox alignment="CENTER" spacing="15.0">
                    <children>
                        <TextField fx:id="searchInput" managed="true" prefWidth="200.0" promptText="Search task" styleClass="search-input" visible="true" />
                        <ComboBox fx:id="sortTaskComboBox" managed="false" prefWidth="120.0" promptText="Sort by" styleClass="clean-input" visible="false" />
                        <Button fx:id="sortTaskBtn" mnemonicParsing="false" onAction="#handleSortClick" styleClass="icon-btn" text="⇅" />
                        <Button fx:id="newTaskBtn" minWidth="84.0" mnemonicParsing="false" styleClass="btn-new" text="+ New" />
                    </children>
                </HBox>
            </children>
         <padding>
            <Insets left="10.0" right="10.0" />
         </padding>
        </HBox>

        <VBox prefHeight="600.0" prefWidth="1058.0" VBox.vgrow="ALWAYS">
            <VBox fx:id="taskGroupsContainer" layoutY="-2.0" prefHeight="565.0" prefWidth="1058.0" spacing="20.0">
                <children>
                    <VBox prefWidth="1058.0" styleClass="task-list-container" VBox.vgrow="ALWAYS">
                        <children>
                            <GridPane alignment="CENTER_LEFT" styleClass="task-header-area">
                                <padding>
                                <Insets left="10.0" right="25.0" />
                                </padding>
                                <VBox.margin>
                                    <Insets />
                                </VBox.margin>
                                <columnConstraints>
                                    <ColumnConstraints hgrow="ALWAYS" minWidth="100.0" prefWidth="450.0" />
                                    <ColumnConstraints halignment="CENTER" hgrow="NEVER" minWidth="100.0" prefWidth="150.0" />
                                    <ColumnConstraints halignment="CENTER" hgrow="NEVER" minWidth="100.0" prefWidth="150.0" />
                                    <ColumnConstraints halignment="CENTER" hgrow="NEVER" minWidth="100.0" prefWidth="150.0" />
                                    <ColumnConstraints halignment="CENTER" hgrow="NEVER" minWidth="100.0" prefWidth="150.0" />
                                </columnConstraints>
                                <rowConstraints>
                                    <RowConstraints minHeight="50.0" prefHeight="50.0" vgrow="SOMETIMES" />
                                </rowConstraints>
                                <children>
                                    <Label styleClass="task-header" text="Task name" GridPane.columnIndex="0">
                                        <GridPane.margin><Insets left="20.0" /></GridPane.margin>
                                    </Label>
                                    <Label styleClass="task-header" text="Due date" GridPane.columnIndex="1" />
                                    <Label styleClass="task-header" text="Assignee" GridPane.columnIndex="2" />
                                    <Label styleClass="task-header" text="Priority" GridPane.columnIndex="3" />
                                    <Label styleClass="task-header" text="Status" GridPane.columnIndex="4" />
                                </children>
                                <VBox.margin>
                                   <Insets />
                                </VBox.margin>
                            </GridPane>
                            <ScrollPane fitToWidth="true" styleClass="scroll-pane" vbarPolicy="ALWAYS" VBox.vgrow="ALWAYS">
                                <content>
                                    <VBox fx:id="taskItemsContainer" spacing="10.0">
                                        <padding>
                                            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                        </padding>
                                    </VBox>
                                </content>
                            </ScrollPane>
                        </children>
                    </VBox>
                </children>
            </VBox>
            <VBox.margin>
                <Insets bottom="10" left="10.0" right="10.0" top="15.0" />
            </VBox.margin>
        </VBox>
        <HBox alignment="BOTTOM_RIGHT" prefWidth="1081.0" spacing="15.0">
            <Button fx:id="cancelBtn" cancelButton="true" minHeight="35.0" minWidth="80.0" mnemonicParsing="false" onAction="#handleCancel" styleClass="btn-cancel" text="Cancel" textAlignment="CENTER" />
        </HBox>
    </children>
</VBox>
