<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.group4.projects_management_fe.features.mainlayout.NotificationsController"
      prefWidth="450" prefHeight="250"
      styleClass="noti-box"
      stylesheets="@../assets/css/notifications.css">

    <Label text="Notifications"
           styleClass="noti-title"
           maxWidth="Infinity"/>

    <ListView fx:id="notificationList"
              prefHeight="200"
              styleClass="noti-list"/>
</VBox>
