<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<StackPane alignment="CENTER" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.group4.projects_management_fe.features.dashboard.DashboardController">
    <!-- DASHBOARD CONTENT -->
    <VBox spacing="25" styleClass="main-container" stylesheets="@../assets/css/dashboard.css">

        <VBox spacing="15" style="-fx-background-color: #E9E9E9; -fx-border-radius: 20px; -fx-background-radius: 20px; -fx-padding: 20px;" styleClass="overview-section">

            <HBox alignment="CENTER_LEFT" spacing="10">

                <Label styleClass="title" text="Overview" />

                <Region HBox.hgrow="ALWAYS" />

                <Button styleClass="filter-btn" text="Last 30 days">
                    <HBox.margin>
                        <Insets right="20" />
                    </HBox.margin>
                </Button>

            </HBox>


            <HBox alignment="CENTER" spacing="40" styleClass="card-container">

                <VBox prefWidth="350" styleClass="card">
                    <Label styleClass="card-title" text="Total Project" />
                    <Label styleClass="card-number" text="64" />
                </VBox>

                <VBox prefWidth="350" styleClass="card">
                    <Label styleClass="card-title" text="Total Tasks" />
                    <Label styleClass="card-number" text="95" />
                </VBox>

                <VBox prefWidth="350" styleClass="card">
                    <Label styleClass="card-title" text="Assigned Tasks" />
                    <Label styleClass="card-number" text="12" />
                </VBox>

                <VBox prefWidth="350" styleClass="card">
                    <Label styleClass="card-title" text="Completed Tasks" />
                    <Label styleClass="card-number" text="30" />
                </VBox>

            </HBox>

        </VBox>


        <!-- MAIN GRID -->
        <GridPane hgap="20" vgap="20">

            <columnConstraints>
                <ColumnConstraints percentWidth="50" />
                <ColumnConstraints percentWidth="25" />
                <ColumnConstraints percentWidth="25" />
            </columnConstraints>

            <!-- PROJECT SUMMARY -->
            <VBox styleClass="box" GridPane.columnIndex="0" GridPane.rowIndex="0">

                <HBox alignment="CENTER_LEFT" spacing="10">

                    <Label styleClass="box-title" text="Project summary" />

                    <Region HBox.hgrow="ALWAYS" />

                    <Button styleClass="icon-btn">
                        <graphic>
                            <Label text="⇅" />
                        </graphic>
                    </Button>

                    <Button onAction="#openPopup" styleClass="new-btn" text="+ New" />

                </HBox>

                <TableView prefHeight="200" prefWidth="620" styleClass="project-table">

                    <columns>
                        <TableColumn maxWidth="220" minWidth="220" prefWidth="220" text="Project name" />
                        <TableColumn maxWidth="140" minWidth="140" prefWidth="140" text="Project manager" />
                        <TableColumn maxWidth="140" minWidth="140" prefWidth="140" text="Due date" />
                        <TableColumn maxWidth="120" minWidth="120" prefWidth="120" text="Status" />
                    </columns>

                </TableView>

            </VBox>

            <!-- CALENDAR -->
            <VBox styleClass="box" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <VBox fx:id="calendarBox" />
            </VBox>

            <!-- REVIEW -->
            <VBox spacing="15" styleClass="box" GridPane.columnIndex="2" GridPane.rowIndex="0">

                <Label styleClass="box-title" text="Review" />

                <Pane styleClass="review-box" />
                <Pane styleClass="review-box" />
                <Pane styleClass="review-box" />

            </VBox>

            <!-- TODAY TASK -->
            <VBox spacing="15" styleClass="box" GridPane.columnIndex="0" GridPane.rowIndex="1">

                <Label styleClass="box-title" text="Today task" />

                <HBox spacing="25" styleClass="task-tabs">
                    <Label styleClass="task-tab-active" text="All" />
                    <Label text="Important" />
                </HBox>

                <Separator />

                <ListView fx:id="taskListView" prefHeight="220" />

            </VBox>

            <!-- NOTE -->
            <VBox styleClass="box" GridPane.columnIndex="1" GridPane.rowIndex="1">

                <Label styleClass="box-title" text="Note" />

                <TextArea prefHeight="200" />

            </VBox>

            <rowConstraints>
                <RowConstraints percentHeight="50" />
                <RowConstraints percentHeight="50" />
            </rowConstraints>

        </GridPane>

    </VBox>


    <StackPane fx:id="overlay" onMouseClicked="#closePopup" style="-fx-background-color: rgba(0,0,0,0.8); -fx-alignment: CENTER; visibility: true;" visible="false" StackPane.alignment="CENTER">

        <children>

            <!-- POPUP -->
            <VBox maxHeight="450" maxWidth="720" onMouseClicked="#consumeMouseEvent" prefWidth="720" style="-fx-background-color:white;                          -fx-border-radius:20;                          -fx-background-radius:20;                          -fx-padding:30;                          -fx-effect:dropshadow(three-pass-box, rgba(0,0,0,0.3),20,0,0,10);">

                <children>

                    <!-- TITLE -->
                    <Label style="-fx-font-size:22px; -fx-font-weight:bold;" text="Project name" />

                    <HBox fx:id="createProjectPopup" maxHeight="450" maxWidth="720" onMouseClicked="#consumeMouseEvent" prefWidth="720" spacing="30" style="-fx-background-color:white;">

                        <VBox.margin>
                            <Insets bottom="30" left="30" right="30" top="30" />
                        </VBox.margin>

                        <!-- LEFT SIDE -->
                        <VBox maxWidth="350.0" minWidth="350.0" prefWidth="360" spacing="18" HBox.hgrow="ALWAYS">

                            <GridPane hgap="16" vgap="18">

                                <columnConstraints>
                                    <ColumnConstraints percentWidth="32.0" />
                                    <ColumnConstraints percentWidth="68.0" />
                                </columnConstraints>

                                <!-- START DATE -->
                                <HBox alignment="CENTER_LEFT"
                                      maxWidth="100.0"
                                      minWidth="50.0"
                                      prefHeight="26.0"
                                      prefWidth="50.0"
                                      spacing="10">

                                    <Label text="📅" />
                                    <Label text="Start date"
                                           style="-fx-font-size:14; -fx-text-fill:#777;" />
                                </HBox>

                                <DatePicker GridPane.columnIndex="1"
                                            style="-fx-background-color:#f5f5f5; -fx-border-color:transparent; -fx-background-radius:8;" />


                                <!-- END DATE -->
                                <HBox alignment="CENTER_LEFT"
                                      maxWidth="100.0"
                                      minWidth="50.0"
                                      prefWidth="50.0"
                                      spacing="10"
                                      GridPane.rowIndex="1">

                                    <Label text="📅" />
                                    <Label text="End date"
                                           style="-fx-font-size:14; -fx-text-fill:#777;" />
                                </HBox>

                                <DatePicker GridPane.columnIndex="1"
                                            GridPane.rowIndex="1"
                                            style="-fx-background-color:#f5f5f5; -fx-border-color:transparent; -fx-background-radius:8;" />


                                <!-- STATUS -->
                                <HBox alignment="CENTER_LEFT"
                                      maxWidth="100.0"
                                      minWidth="50.0"
                                      prefWidth="50.0"
                                      spacing="10"
                                      GridPane.rowIndex="2">

                                    <Label text="☑" />
                                    <Label text="Status"
                                           style="-fx-font-size:14; -fx-text-fill:#777;" />
                                </HBox>

                                <Button fx:id="statusBtn"
                                        text="Empty"
                                        onAction="#showStatusMenu"
                                        GridPane.columnIndex="1"
                                        GridPane.rowIndex="2"
                                        style="-fx-background-color:#f5f5f5; -fx-background-radius:8;" />


                                <!-- MEMBER -->
                                <HBox alignment="CENTER_LEFT"
                                      maxWidth="100.0"
                                      minWidth="50.0"
                                      prefWidth="50.0"
                                      spacing="10"
                                      GridPane.rowIndex="3">

                                    <Label text="👥" />
                                    <Label text="1 member"
                                           style="-fx-font-size:14; -fx-text-fill:#777;" />
                                </HBox>

                                <Label text="No member selected"
                                       GridPane.columnIndex="1"
                                       GridPane.rowIndex="3"
                                       style="-fx-font-size:14;" />


                                <!-- DESCRIPTION -->
                                <HBox alignment="CENTER_LEFT"
                                      spacing="10"
                                      GridPane.rowIndex="4">

                                    <Label text="≡" />
                                    <Label text="Description:"
                                           style="-fx-font-size:14; -fx-text-fill:#777;" />
                                </HBox>

                                <TextArea prefHeight="80"
                                          promptText="Add a description..."
                                          GridPane.columnIndex="1"
                                          GridPane.rowIndex="4"
                                          style="-fx-border-color:transparent; -fx-background-color:#f5f5f5; -fx-background-radius:8;" />
                        <rowConstraints>
                           <RowConstraints />
                           <RowConstraints />
                           <RowConstraints />
                           <RowConstraints />
                           <RowConstraints />
                        </rowConstraints>

                            </GridPane>

                        </VBox>


                        <!-- RIGHT SIDE -->
                        <VBox minWidth="360.0" spacing="18" style="-fx-padding:0 0 0 20;                                      -fx-border-color:transparent transparent transparent #eeeeee;">

                            <!-- CREATED BY -->
                            <VBox spacing="6">

                                <Label style="-fx-font-size:13px; -fx-text-fill:#888;" text="Created by" />

                                <HBox alignment="CENTER_LEFT" spacing="10">

                                    <Circle radius="18" style="-fx-fill:linear-gradient(to right,#7b5cff,#9f7aea);" />

                                    <VBox>

                                        <Label style="-fx-font-weight:600;" text="NamInvincible" />

                                        <Label style="-fx-font-size:11px; -fx-text-fill:#888;" text="Feb 14, 2026, 11:32 PM" />

                                    </VBox>

                                </HBox>

                            </VBox>


                            <!-- CO MANAGER -->
                            <VBox spacing="8">

                                <Label style="-fx-font-size:13px; -fx-text-fill:#888;" text="Add Co-Manager" />

                                <Button style="-fx-background-color:#f3f3f3;                                                -fx-background-radius:50;                                                -fx-pref-width:32;                                                -fx-pref-height:32;" text="+" />

                            </VBox>


                            <!-- LAST UPDATE -->
                            <VBox spacing="6">

                                <Label style="-fx-font-size:13px; -fx-text-fill:#888;" text="Last updated by" />

                                <HBox spacing="10">

                                    <Circle radius="16" style="-fx-fill:linear-gradient(to right,#7b5cff,#9f7aea);" />

                                    <VBox>

                                        <Label style="-fx-font-weight:600;" text="NamInvincible" />

                                        <Label style="-fx-font-size:11px; -fx-text-fill:#888;" text="Feb 14, 2026, 11:32 PM" />

                                    </VBox>

                                </HBox>

                            </VBox>


                            <Region VBox.vgrow="ALWAYS" />


                            <!-- BUTTONS -->
                            <HBox alignment="CENTER_RIGHT" spacing="10">

                                <Button onAction="#closePopup" style="-fx-background-color:#eeeeee;                                                -fx-background-radius:8;" text="Cancel" />

                                <Button style="-fx-background-color:linear-gradient(to right,#7b5cff,#9f7aea);                                                -fx-text-fill:white;                                                -fx-background-radius:8;" text="Create" />

                            </HBox>

                        </VBox>

                    </HBox>

                </children>

            </VBox>

        </children>
    </StackPane>

</StackPane>
