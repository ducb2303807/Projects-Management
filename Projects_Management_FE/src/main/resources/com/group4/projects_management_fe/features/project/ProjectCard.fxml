<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.shape.Circle?>

<AnchorPane prefHeight="180.0" prefWidth="320.0" styleClass="main-card-container" stylesheets="@../assets/css/project.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
    <children>

        <ImageView fitHeight="180.0" fitWidth="320.0" pickOnBounds="true" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <image>
                <Image url="@../assets/image/folder_v4.png" />
            </image>
        </ImageView>

        <AnchorPane styleClass="content-pane" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <HBox alignment="CENTER" spacing="5.0" styleClass="status-badge" AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="15.0">
                    <children>
                        <Label styleClass="status-text" text="⌛ On going" />
                    </children>
                </HBox>

                <Label prefWidth="250.0" styleClass="project-title" text="Write a proposal for Inc." wrapText="true" AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="65.0" />

                <Label styleClass="ellipsis" text="•••" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="60.0" />

                <Label styleClass="icon-text" text="📅 Nov 23, 2026, 8:50 AM" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="20.0" />

                <HBox alignment="CENTER" spacing="4.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="10.0">
                    <children>
                        <Label styleClass="creator-label" text="Created by" />
                        <Label styleClass="creator-name" text="Hunny" />
                        <Circle radius="8.0" styleClass="avatar-circle">
<!--                            <fill>-->
<!--                                <Color web="#2c3e50" />-->
<!--                            </fill>-->
                        </Circle>
                    </children>
                </HBox>
            </children>
        </AnchorPane>

    </children>
</AnchorPane>