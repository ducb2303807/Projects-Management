<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToHeight="true" fitToWidth="true" maxHeight="Infinity" maxWidth="Infinity" styleClass="main-view-bg" stylesheets="@../assets/css/project/project.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.group4.projects_management_fe.features.project.ProjectController">
    <content>
        <VBox spacing="20.0" styleClass="project-container">
            <padding>
                <Insets bottom="20.0" left="150.0" right="150.0" top="20.0" />
            </padding>

            <VBox spacing="10.0">
                <children>
                    <Label styleClass="section-subtitle" text="⏱ Recently visited" />
                    <HBox fx:id="recentCardsContainer" alignment="TOP_CENTER" spacing="20.0" styleClass="recently-container">
                        <padding>
                            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                        </padding>
                    </HBox>
                </children>
            </VBox>

            <VBox spacing="15.0" VBox.vgrow="ALWAYS">
                <children>
                    <HBox alignment="CENTER_LEFT">
                        <children>
                            <Label styleClass="section-title" text="Projects" />
                            <Region HBox.hgrow="ALWAYS" />

                            <HBox alignment="CENTER" spacing="15.0">
                                <children>
                                    <TextField fx:id="searchInput" managed="false" prefWidth="200.0" promptText="Search project..." styleClass="search-input" visible="false" />

                                    <Button fx:id="searchBtn" mnemonicParsing="false" onAction="#handleSearchToggle" styleClass="icon-btn" text="🔍" />
                                    <ComboBox fx:id="sortCriteriaComboBox" managed="false" prefWidth="120.0" promptText="Sort by" styleClass="clean-input" visible="false" />
                                    <Button fx:id="sortBtn" mnemonicParsing="false" onAction="#handleSortClick" styleClass="icon-btn" text="⇅" />

                                    <Button mnemonicParsing="false" onAction="#openNewProjectPopup" styleClass="btn-new" text="+ New" />
                                </children>
                            </HBox>
                        </children>
                    </HBox>

                    <HBox alignment="CENTER" styleClass="project-content-container">
                        <children>
                            <GridPane fx:id="mainCardsContainer" alignment="CENTER" hgap="30.0" vgap="25.0">
                                <padding>
                                    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                                </padding>
                            </GridPane>
                        </children>
                    </HBox>
                </children>
            </VBox>

        </VBox>
    </content>
</ScrollPane>
