<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" styleClass="main-view-bg" stylesheets="@../assets/css/project.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.group4.projects_management_fe.features.project.ProjectController">
    <content>
        <VBox spacing="20.0">
            <padding>
                <Insets bottom="20.0" left="150.0" right="150.0" top="20.0" />
            </padding>

            <VBox spacing="10.0">
                <children>
                    <Label styleClass="section-subtitle" text="⏱ Recently visited" />
                    <HBox fx:id="recentCardsContainer" alignment="TOP_CENTER" spacing="20.0" style="-fx-background-color: rgba(233, 233, 233, 0.35);">
                        <padding>
                            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                        </padding>
                    </HBox>
                </children>
            </VBox>

            <VBox spacing="15.0" VBox.vgrow="ALWAYS">
                <children>
                    <HBox alignment="CENTER_LEFT">
                        <children>
                            <Label styleClass="section-title" text="Projects (5)" />
                            <Region HBox.hgrow="ALWAYS" />

                            <HBox alignment="CENTER" spacing="15.0">
                                <children>
                                    <Label styleClass="icon-btn" text="🔍" />
                                    <Label styleClass="icon-btn" text="⇅" />
                                    <Button mnemonicParsing="false" onAction="#openNewProjectPopup" styleClass="btn-new" text="+ New" />
                                </children>
                            </HBox>
                        </children>
                    </HBox>

                    <FlowPane fx:id="mainCardsContainer" alignment="TOP_CENTER" hgap="30.0" style="-fx-background-color: rgba(233, 233, 233, 0.35);" vgap="25.0">
                        <padding>
                            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                        </padding>
                    </FlowPane>
                </children>
            </VBox>

        </VBox>
    </content>
</ScrollPane>
